	(text "For Trip current 2x rated I trip = 8x2= 16A ,Rshunt = 0.11 Ω\n-> I1+I2=16\n-> 0.11 I2 = I1(R1+R2)\n-> I1 x R2 = 0.5 V\n2.52 R2 = R1 + 0.11\nif R2 = 1kΩ then R1 = 2.72kΩ \nTRIMMER 10KΩ"
		(exclude_from_sim no)
		(at 160.528 203.708 0)
		(effects
			(font
				(face "Times New Roman")
				(size 1.27 1.27)
				(bold yes)
				(color 126 126 126 1)
			)
			(justify left)
		)
		(uuid "6f1f34bc-a0ed-4864-b643-080053949c00")
	)
	(text "I2"
